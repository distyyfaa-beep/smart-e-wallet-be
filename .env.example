APP_NAME=ewall
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-be-service.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── Database (dari Railway MySQL service) ─────────────────────
DB_CONNECTION=mysql
DB_HOST=your-mysql-host.railway.internal
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

# ─── Session & Cache ───────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── CORS — URL frontend Railway ──────────────────────────────
FRONTEND_URL=https://your-fe-service.up.railway.app

# ─── Sanctum ──────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=your-fe-service.up.railway.app

# ─── Mail (opsional) ──────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@ewall.app"
MAIL_FROM_NAME="${APP_NAME}"
